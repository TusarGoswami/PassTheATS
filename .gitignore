# === PassTheATS Ultra Max .gitignore ===

# 🔐 Secrets & Environment Variables
# Essential: Never push these to a public repo
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env/
secrets.py

# 🐍 Python Basics
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 🏗️ Virtual Environments
venv/
ENV/
env.bak/
venv.bak/

# 🧪 Flask / SQLAlchemy
instance/
.webassets-cache
# Ignore the SQLite database
*.db
*.sqlite3

# 📂 Project Specific: User Content
# We ignore the actual files but keep the directory structure
uploads/*
!uploads/.gitkeep
# 🖥️ OS & Editors
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# 🛠️ IDEs (VS Code, PyCharm)
.vscode/
.idea/
*.swp
*.swo

# 📦 Logs & Misc
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*